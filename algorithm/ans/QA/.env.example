# =============================================================================
# 图谱问答 QA 专用（可选）
#
# 推荐：在仓库根 .env 或 backend/.env 中配置 NEO4J_*、LLM_*，后端启动时会先加载上述文件，
# 本目录 .env 仅在 import QA 时以 load_dotenv(override=False) 加载，不会覆盖已存在的环境变量。
#
# 仅在本文件维护时，至少配置：
# =============================================================================

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j2025

LLM_TYPE=qwen-plus
LLM_API_KEY=your-dashscope-api-key

MAX_LENGTH=256
TEMPERATURE_EXPLORATION=0.4
TEMPERATURE_REASONING=0.0

WIDTH=3
DEPTH=3
NUM_RETAIN_ENTITY=5
PRUNE_TOOLS=llm
REMOVE_UNNECESSARY_REL=true
AUTO_ENTITY_LINKING=true

VISUALIZATION_DIR=visualizations
ENABLE_VISUALIZATION=true

API_HOST=0.0.0.0
API_PORT=5000
DEBUG=true
