@startuml

' --- 核心类定义 ---

abstract class RuleType {
    - RuleId: String
    - RuleName: String
    - Terminology: List<String>
    - RuleTypeBody: RuleTypeBody // 核心逻辑容器
}

' 定义这个“容器”类，它是一个多态组合
abstract class RuleTypeBody {
}

class ConstraintRuleType {
    - subject: String
    - constraint: String
}

class ImplicationRuleType {
    - antecedent: String
    - consequent: String
    - connectionSymbol: String
}

class CompositeRuleType {
    - CombinationType: String // AND / OR / SEQUENCE
    - SubRules: List<RuleTypeBody> // 这里递归指向逻辑体
}

' --- 关系定义 ---

' RuleType 包含一个 RuleTypeBody
RuleType *-- RuleTypeBody

' 三种具体的逻辑类型继承自 RuleTypeBody
RuleTypeBody <|-- ConstraintRuleType
RuleTypeBody <|-- ImplicationRuleType
RuleTypeBody <|-- CompositeRuleType

' 复合规则递归包含多个逻辑体
CompositeRuleType "1" o-- "0..*" RuleTypeBody : SubRules

@enduml