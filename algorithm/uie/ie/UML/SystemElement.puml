@startuml

' --- 抽象类/元类定义 ---

abstract class SystemElement <<metaclass>> {
    - id: String
    - name: String
    - generalclass: String // 基类
    - terminology: String // 对应术语
    - version: String
    - creationDate: Date
    - source: String // 来源
    - description: String // 来源于标准
}

note top of SystemElement: 系统的核心抽象元素，所有具体构件的基类

class Attributes <<metaclass>> {
    - name: String
    - description: String
}

class Features <<metaclass>> {
    - name: String
    - description: String
}

class Constraints <<metaclass>> {
    - name: String
    - description: String
}

class Operations <<metaclass>> {
    - name: String
    - description: String
}

' --- 关系定义 ---

SystemElement "1" *-- "0..*" Attributes : has >
SystemElement "1" *-- "0..*" Features : has >
SystemElement "1" *-- "0..*" Constraints : has >
SystemElement "1" *-- "0..*" Operations : has >

@endum