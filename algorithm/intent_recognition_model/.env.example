# =============================================================================
# 意图识别模块 — 可选：仅当你「单独在本目录跑脚本」（如 init_database）时使用本文件。
#
# 通过后端 API / uvicorn 使用时：请在 backend/.env 配置 MILVUS_*、MODEL_PATH、
# INTENT_MODEL_BASE_DIR、LLM_*、NEO4J_* 等（与下列变量名一致，见 backend/.env.example）。
# =============================================================================

MILVUS_URI=http://127.0.0.1:19530
MILVUS_CONSISTENCY_LEVEL=Strong
COLLECTION_NAME=intent_rag

# BGE-M3 模型目录（内含 config.json 等）。推荐其一：
# - 仓库根相对路径，不依赖从哪一级目录启动 uvicorn：models/bge_m3 或 models/bge_m3_model
# - 绝对路径：/your/path/bge_m3_model
# 不设 MODEL_PATH 时，会在 INTENT_MODEL_BASE_DIR（默认 仓库根/models）下自动查找 bge_m3、bge_m3_model
MODEL_PATH=
# INTENT_MODEL_BASE_DIR=
DATA_DIR=
LOG_PATH=

DEEPSEEK_API_KEY=
LLM_BASE_URL=http://127.0.0.1:9999
LLM_MODEL=Qwen/Qwen3-8B

NEO4J_URI=neo4j://127.0.0.1:7687
# 用户名支持 NEO4J_USERNAME 或与全项目统一的 NEO4J_USER
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j2025

MAX_DROP_RETRIES=3
DROP_RETRY_DELAY=2
