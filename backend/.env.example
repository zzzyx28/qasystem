# =============================================================================
# backend/.env（本机 uvicorn 主配置）
# 复制为 backend/.env 后用于本机运行：uvicorn app.main:app --reload --port 8000
#
# 边界约定：
# 1) 本文件只服务“本机后端运行”；Docker Compose 请使用仓库根 /.env
# 2) 不要在本文件放 Compose 专属变量（如 MYSQL_ROOT_PASSWORD / HTTP_PORT / MYSQL_BIND）
# 3) 加载顺序：backend/.env（override=True）→ 根 /.env（override=False，仅补缺）
# =============================================================================

# ----- MySQL（业务库：用户、文档元数据）-----
DATABASE_URL=mysql+asyncmy://rail_user:123456@127.0.0.1:3306/rail_assistant

# ----- Dify（智能问答、知识库 API；地址必须以 /v1 结尾）-----
DIFY_API_URL=http://127.0.0.1/v1
DIFY_API_KEY=
DIFY_KNOWLEDGE_API_KEY=

DIFY_USE_WORKFLOW=false
DIFY_WORKFLOW_API_KEY=
DIFY_WORKFLOW_INPUT_VAR=query
DIFY_WORKFLOW_OUTPUT_VAR=text
DIFY_WORKFLOW_RESPONSE_MODE=blocking
DIFY_WORKFLOW_TIMEOUT_SECONDS=120

# ----- JWT -----
JWT_SECRET=change-me-dev-only
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# production 时勿使用默认 JWT_SECRET
ENVIRONMENT=development

# ----- 与 Docker 根 /.env 的关系 -----
# 建议同名键保持语义一致，例如：
# - 本机：NEO4J_URI=bolt://127.0.0.1:7687
# - Docker：NEO4J_URI=bolt://host.docker.internal:7687 或 bolt://neo4j:7687

# ----- 用户与权限 -----
# 是否允许 POST /api/auth/register 公开注册（关闭后仅管理员可在「用户管理」中创建账号）
PUBLIC_REGISTRATION_ENABLED=true
# 可选：启动时确保该账号存在且为管理员（用于生产首启或找回管理员；会覆盖该用户密码）
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=please-change-me

# ----- Neo4j（答案生成 QA、图谱更新、抽取落库、意图检索图、冲突检测）-----
# 冲突检测另支持 CONFLICT_NEO4J_*；未设置时自动回退到下列变量
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j2025
# CONFLICT_NEO4J_URI=
# CONFLICT_NEO4J_USER=
# CONFLICT_NEO4J_PWD=

# ----- 统一 LLM（algorithm/common/llm_client.py；多模块复用）-----
# 后端类型: openai | ollama | zhipu（本地 vLLM 一般用 openai 兼容 + LLM_BASE_URL）
LLM_BACKEND=openai
LLM_BASE_URL=http://127.0.0.1:9999
LLM_MODEL=Qwen/Qwen3-8B
LLM_API_KEY=
# 兼容别名（任选其一）
# OPENAI_BASE_URL=
# OPENAI_API_KEY=
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL_NAME=

# ----- 意图识别（Milvus + LLM；也可单独使用 algorithm/intent_recognition_model/.env）-----
MILVUS_URI=http://127.0.0.1:19530
MILVUS_CONSISTENCY_LEVEL=Strong
COLLECTION_NAME=intent_rag
# BGE-M3：推荐 models/bge_m3 或 models/bge_m3_model（相对仓库根，不依赖 uvicorn 启动目录）
# 避免仅写 ../bge_m3_model（从仓库根启动时会解析到仓库外）
MODEL_PATH=
DATA_DIR=
LOG_PATH=
DEEPSEEK_API_KEY=
MAX_DROP_RETRIES=3
DROP_RETRY_DELAY=2
# 意图模块 Neo4j 亦读 NEO4J_URI / NEO4J_USER(或 NEO4J_USERNAME) / NEO4J_PASSWORD

# ----- 知识抽取 UIE（backend 组件）-----
UIE_LLM_MODEL=rule_v4
UIE_CHUNK_MAX_CHARS=1200
UIE_MAX_OUTPUT_TOKENS=768

# ----- 文档预处理 MinerU（可选）-----
MINERU_MODEL_SOURCE=local
MINERU_CONFIG_PATH=
# 可选：覆盖 mineru.json 中 models-dir 的 pipeline / vlm 路径（推荐）
MINERU_MODEL_PIPELINE_PATH=/absolute/path/to/models/hub/models/OpenDataLab/PDF-Extract-Kit-1___0
MINERU_MODEL_VLM_PATH=/absolute/path/to/models/hub/models/OpenDataLab/MinerU2___5-2509-1___2B

# ----- NL2Cypher（路径默认相对 algorithm/NL_to_cypher，不依赖 cwd）-----
# NL2CYPHER_CHROMA_DB_PATH=chroma_db
# NL2CYPHER_EMBEDDING_MODEL_PATH=models/bge-small-zh-v1.5
# NL2CYPHER_RECORDS_JSON=records.json

# ----- 文档预处理 -----
# LIBREOFFICE_PATH=
# SOFFICE_PATH=

# ----- 置信度 / ES（algorithm/confidence_calculate，可选）-----
# CONFIDENCE_SBERT_MODEL_PATH=
# CONFIDENCE_ES_HOSTS=http://127.0.0.1:9200
# CONFIDENCE_ES_USERNAME=
# CONFIDENCE_ES_PASSWORD=

# ----- 意图识别模型默认目录（未设置 MODEL_PATH 时在此目录下查找 bge_m3 / bge_m3_model）-----
# INTENT_MODEL_BASE_DIR=/path/to/qasystem/models

# ----- 图谱更新置信度阈值（覆盖 config.json）-----
# KG_CONFIDENCE_THRESHOLD=0.7

# ----- CORS（局域网前端联调，逗号分隔）-----
# CORS_ORIGINS=http://localhost:5173,http://192.168.1.10:5173

# ----- 图谱问答 QA（algorithm/ans/QA；亦可使用 QA/.env，默认不覆盖已存在环境变量）-----
# LLM_TYPE=glm-4.7
# MAX_LENGTH=256
# TEMPERATURE_EXPLORATION=0.4
# TEMPERATURE_REASONING=0.0
# WIDTH=3
# DEPTH=3
# VISUALIZATION_DIR=visualizations
# ENABLE_VISUALIZATION=true
