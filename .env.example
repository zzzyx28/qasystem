# =============================================================================
# 仓库根 .env（仅用于 Docker Compose）
# 复制为 /.env 后执行：docker compose up -d --build
#
# 边界约定：
# 1) 本文件服务于 Docker Compose（端口、MySQL、注入 backend 容器的环境变量）
# 2) 本机 uvicorn 调试请使用 backend/.env（见 backend/.env.example）
# 3) 不要在本文件配置 DATABASE_URL：compose 会在 backend 服务内强制覆盖为 @db:3306
# =============================================================================

# ----- Compose 基础 -----
HTTP_PORT=80
MYSQL_BIND=127.0.0.1
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=rail_assistant
MYSQL_USER=rail
MYSQL_PASSWORD=rail123
# backend 连接数据库地址（默认 compose 内 db；外部库可改成内网地址）
DATABASE_HOST=db
DATABASE_PORT=3306
# 宿主机模型目录（将以只读方式挂载到 backend 容器 /models）
HOST_MODELS_DIR=/opt/qasystem-models

# 可选：启用 compose neo4j profile 时的端口绑定
NEO4J_HTTP_BIND=127.0.0.1
NEO4J_BOLT_BIND=127.0.0.1

# ----- backend 容器运行所需（通过 env_file 注入）-----
ENVIRONMENT=development
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Dify
DIFY_API_URL=https://api.dify.ai/v1
DIFY_API_KEY=
DIFY_KNOWLEDGE_API_KEY=
DIFY_USE_WORKFLOW=false
DIFY_WORKFLOW_API_KEY=
DIFY_WORKFLOW_INPUT_VAR=query
DIFY_WORKFLOW_OUTPUT_VAR=text
DIFY_WORKFLOW_RESPONSE_MODE=blocking
DIFY_WORKFLOW_TIMEOUT_SECONDS=120

# 外部依赖地址（容器内访问宿主机示例）
# 若使用 compose --profile neo4j，请改为 NEO4J_URI=bolt://neo4j:7687
NEO4J_URI=bolt://host.docker.internal:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j2025

LLM_BACKEND=openai
LLM_BASE_URL=http://host.docker.internal:9999
LLM_MODEL=Qwen/Qwen3-8B
LLM_API_KEY=
OLLAMA_URL=

MILVUS_URI=http://host.docker.internal:19530
MILVUS_CONSISTENCY_LEVEL=Strong
COLLECTION_NAME=intent_rag
DEEPSEEK_API_KEY=

# 组件可选项（仅在需要对应组件时填写；不需要可留空）
MODEL_PATH=/models/bge_m3_model
INTENT_MODEL_BASE_DIR=/models
UIE_LLM_MODEL=rule_v4
UIE_CHUNK_MAX_CHARS=1200
MINERU_MODEL_SOURCE=local
MINERU_CONFIG_PATH=/app/algorithm/preproc/mineru.json
# 可选：直接通过环境变量覆盖 mineru.json 的 models-dir（部署推荐）
MINERU_MODEL_PIPELINE_PATH=/models/hub/models/OpenDataLab/PDF-Extract-Kit-1___0
MINERU_MODEL_VLM_PATH=/models/hub/models/OpenDataLab/MinerU2___5-2509-1___2B
LIBREOFFICE_PATH=
NL2CYPHER_CHROMA_DB_PATH=chroma_db
NL2CYPHER_EMBEDDING_MODEL_PATH=/models/bge-small-zh-v1.5
NL2CYPHER_RECORDS_JSON=records.json
CONFIDENCE_ES_HOSTS=http://127.0.0.1:9200
CONFIDENCE_SBERT_MODEL_PATH=/models/sbert_model
KG_CONFIDENCE_THRESHOLD=
CORS_ORIGINS=
